      ]
    },
    {
      "type": "code",
      "lang": "html",
      "langLabel": "HTML",
      "code": [
        "<video src=\"movie.mp4\" controls width=\"400\">",
        "  متصفّحك لا يدعم الفيديو",
        "</video>"
      ],
      "annotations": [
        {
          "line": 1,
          "text": "controls يعرض أزرار التشغيل والصوت."
