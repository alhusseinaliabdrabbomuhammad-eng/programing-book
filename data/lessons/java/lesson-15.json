  "title": "الوراثة extends و super وتجاوز الدوال",
  "subtitle": "كيف ترث فئة خصائص فئة أخرى لتجنّب تكرار الكود؟",
  "minInteractions": 2,
  "sections": [
    {
      "type": "text",
      "heading": "الوراثة",
      "icon": "🧬",
      "content": [
        "الوراثة تتيح لفئة (ابنة) أن ترث خصائص ودوال فئة (أمّ) باستخدام extends. فلا نكرّر الكود المشترك."
      ]
    },
    {
      "type": "code",
      "lang": "java",
      "langLabel": "Java",
      "code": [
        "class Animal {",
        "  void eat() { System.out.println(\"يأكل\"); }",
        "}",
        "class Dog extends Animal {",
        "  void bark() { System.out.println(\"ينبح\"); }",
        "}",
        "Dog d = new Dog();",
        "d.eat();",
        "d.bark();"
      ],
      "annotations": [
        {
          "line": 4,
          "text": "Dog ترث من Animal."
        },
