      "type": "code",
      "lang": "cpp",
      "langLabel": "C++",
      "code": [
        "class Box {",
        "public:",
        "  Box() { cout << \"وُلد\\n\"; }",
        "  ~Box() { cout << \"انتهى\\n\"; }",
        "};",
        "{ Box b; }"
