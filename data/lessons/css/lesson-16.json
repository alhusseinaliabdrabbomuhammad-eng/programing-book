  "sections": [
    {
      "type": "text",
      "heading": "الانتقالات transition",
      "icon": "🎚️",
      "content": [
        "transition تجعل تغيّر الخصائص يحدث بسلاسة بدل القفز المفاجئ. مثالية لتأثيرات التمرير hover."
      ]
    },
    {
      "type": "code",
      "lang": "css",
      "langLabel": "CSS",
      "code": [
        ".btn {",
        "  background: blue;",
        "  transition: background 0.3s;",
        "}",
        ".btn:hover {",
        "  background: green;",
        "}"
      ],
      "annotations": [
        {
          "line": 3,
          "text": "أي تغيّر في الخلفية يحدث خلال 0.3 ثانية بسلاسة."
        },
        {
          "line": 5,
          "text": ":hover يطبّق عند مرور الفأرة."
        },
        {
          "line": 6,
          "text": "يتحوّل اللون تدريجيًّا للأخضر."
        }
      ]
    },
    {
      "type": "text",
      "heading": "التحوّلات transform",
      "icon": "🔄",
      "content": [
        "transform يحرّك العنصر أو يدوّره أو يكبّره دون التأثير على تخطيط الصفحة."
      ]
    },
    {
      "type": "code",
      "lang": "css",
      "langLabel": "CSS",
      "code": [
        ".card:hover {",
        "  transform: scale(1.1);",
        "}"
      ],
      "annotations": [
        {
          "line": 2,
          "text": "scale(1.1) يكبّر العنصر 10% عند التمرير."
