      ]
    },
    {
      "type": "code",
      "lang": "css",
      "langLabel": "CSS",
      "code": [
        "h1 {",
        "  font-size: clamp(1.5rem, 4vw, 3rem);",
        "}"
      ],
      "annotations": [
