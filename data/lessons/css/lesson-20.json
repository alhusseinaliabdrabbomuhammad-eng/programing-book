      "type": "text",
      "heading": "تخطيط احترافيّ",
      "icon": "🏗️",
      "content": [
        "سنصمّم صفحة بثيم ألوان موحّد، تخطيط Grid، وأزرار بتأثيرات ناعمة، ومتجاوبة مع الجوّال."
      ]
    },
    {
      "type": "code",
      "lang": "css",
      "langLabel": "CSS",
      "code": [
        ":root { --primary: #2c3e50; }",
        "body {",
        "  font-family: sans-serif;",
        "  line-height: 1.6;",
        "}",
        ".layout {",
        "  display: grid;",
        "  grid-template-columns: 250px 1fr;",
        "  gap: 20px;",
        "}"
      ],
      "annotations": [
        {
          "line": 1,
          "text": "متغيّر للون الأساسي الموحّد."
        },
        {
          "line": 3,
          "text": "خطّ مريح وتباعد سطور جيّد."
        },
        {
          "line": 6,
          "text": "شبكة: شريط جانبيّ 250px ومحتوى مرن."
        }
      ]
    },
    {
      "type": "code",
      "lang": "css",
      "langLabel": "CSS",
      "code": [
        "@media (max-width: 700px) {",
