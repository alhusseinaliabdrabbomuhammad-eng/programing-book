      "type": "text",
      "heading": "ما التصميم المتجاوب؟",
      "icon": "📱",
      "content": [
        "التصميم المتجاوب يتكيّف مع حجم الشاشة: عمودان على الحاسوب يصبحان عمودًا واحدًا على الجوّال. نحقّقه بـ Media Queries."
      ]
    },
    {
      "type": "code",
      "lang": "css",
      "langLabel": "CSS",
      "code": [
        ".container {",
        "  display: flex;",
        "}",
        "@media (max-width: 600px) {",
        "  .container {",
        "    flex-direction: column;",
        "  }",
        "}"
